<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CimianAdmin.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Reusable card surface. Shadow is applied per-card via Border.Shadow
                 + Translation since Translation can't be set in a Style setter
                 (no string→Vector3 converter for setters in WinUI 3). -->
            <ThemeShadow x:Key="CardShadow" />
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <!-- Lucide SVGs use stroke="currentColor". An implicit Style ties every
                 ImageIcon's foreground to the primary text brush so icons read as
                 white on dark backgrounds and dark on light backgrounds. -->
            <Style TargetType="ImageIcon">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
