<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CimianAdmin.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Reusable card surface. Shadow is applied per-card via Border.Shadow
                 + Translation since Translation can't be set in a Style setter
                 (no string→Vector3 converter for setters in WinUI 3). -->
            <ThemeShadow x:Key="CardShadow" />
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <!-- Lucide icon system: rendered as Path with theme-aware Stroke.
                 Path data strings are stored as x:String resources; sites place a
                 <Viewbox Width="N" Height="N"><Path Style="{StaticResource LucidePath}"
                 Data="{StaticResource LucideXxx}" Width="24" Height="24"/></Viewbox>.
                 ThemeResource for Stroke updates automatically with theme switches.

                 The 5 NavigationViewItem.Icon slots in MainWindow.xaml stay on FontIcon
                 (Segoe Fluent Icons) because IconElement is not user-derivable in WinUI 3
                 and PathIcon fills geometry rather than stroking it. -->
            <Style x:Key="LucidePath" TargetType="shapes:Path">
                <Setter Property="Stroke" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="StrokeThickness" Value="2" />
                <Setter Property="StrokeStartLineCap" Value="Round" />
                <Setter Property="StrokeEndLineCap" Value="Round" />
                <Setter Property="StrokeLineJoin" Value="Round" />
                <Setter Property="Fill" Value="Transparent" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
