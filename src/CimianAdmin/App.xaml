<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CimianAdmin.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Reusable card surface. Shadow is applied per-card via Border.Shadow
                 + Translation since Translation can't be set in a Style setter
                 (no string→Vector3 converter for setters in WinUI 3). -->
            <ThemeShadow x:Key="CardShadow" />
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <!-- Icons across the app use BitmapIcon with ShowAsMonochrome="True"
                 because ImageIcon.Foreground does NOT recolor SvgImageSource — that
                 was the cause of "black-on-black" icons in dark mode. BitmapIcon
                 rasterizes the SVG and recolors non-transparent pixels to Foreground.
                 Default Foreground (when not overridden) is ButtonForeground /
                 NavigationViewItemForeground from the system theme. -->
            <Style TargetType="BitmapIcon">
                <Setter Property="ShowAsMonochrome" Value="True" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
