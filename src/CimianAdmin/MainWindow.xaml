<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CimianAdmin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="40"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Grid.Column="1"
                    Click="OnBackClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="36" Height="32"
                    Margin="0,0,2,0"
                    IsEnabled="False">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
                <ToolTipService.ToolTip>
                    <TextBlock Text="Back" />
                </ToolTipService.ToolTip>
            </Button>
            <Button x:Name="ForwardButton"
                    Grid.Column="2"
                    Click="OnForwardClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="36" Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="False">
                <FontIcon Glyph="&#xE72A;" FontSize="14" />
                <ToolTipService.ToolTip>
                    <TextBlock Text="Forward" />
                </ToolTipService.ToolTip>
            </Button>

            <FontIcon Grid.Column="3"
                      Glyph="&#xE7B8;"
                      FontSize="14"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="AppTitleText"
                       Grid.Column="4"
                       Text="CimianAdmin"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="RepoTitleText"
                       Grid.Column="5"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,140,0"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="500" />
        </Grid>

        <muxc:NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            CompactPaneLength="48"
            OpenPaneLength="240"
            SelectionChanged="NavView_SelectionChanged">

            <muxc:NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            </muxc:NavigationView.Resources>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem x:Name="NavRepository" Tag="repository" Content="Home">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavPackages" Tag="packages" Content="Packages">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B8;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavManifests" Tag="manifests" Content="Manifests">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavCatalogs" Tag="catalogs" Content="Catalogs">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE82D;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
