<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CimianAdmin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="40"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Column 3 historically held a title-bar icon; removed by user request. -->


            <Button x:Name="BackButton"
                    Grid.Column="1"
                    Click="OnBackClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="36" Height="32"
                    Margin="0,0,2,0"
                    IsEnabled="False">
                <BitmapIcon Width="14" Height="14" UriSource="ms-appx:///Assets/arrow-left.svg" ShowAsMonochrome="True" />
                <ToolTipService.ToolTip>
                    <TextBlock Text="Back" />
                </ToolTipService.ToolTip>
            </Button>
            <Button x:Name="ForwardButton"
                    Grid.Column="2"
                    Click="OnForwardClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="36" Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="False">
                <BitmapIcon Width="14" Height="14" UriSource="ms-appx:///Assets/arrow-right.svg" ShowAsMonochrome="True" />
                <ToolTipService.ToolTip>
                    <TextBlock Text="Forward" />
                </ToolTipService.ToolTip>
            </Button>

            <TextBlock x:Name="AppTitleText"
                       Grid.Column="4"
                       Text="CimianAdmin"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="5"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        Margin="0,0,140,0">
                <TextBlock x:Name="RepoTitleText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="360" />
                <Border x:Name="GitIndicator"
                        Visibility="Collapsed"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,2,8,2"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <BitmapIcon Height="14" Width="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" UriSource="ms-appx:///Assets/git-branch.svg" ShowAsMonochrome="True" />
                        <TextBlock x:Name="GitBranchText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="GitAheadBehindText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ToolTipService.ToolTip>
                        <TextBlock x:Name="GitIndicatorTooltip" />
                    </ToolTipService.ToolTip>
                </Border>
            </StackPanel>
        </Grid>

        <muxc:NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            CompactPaneLength="48"
            OpenPaneLength="240"
            SelectionChanged="NavView_SelectionChanged">

            <muxc:NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            </muxc:NavigationView.Resources>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem x:Name="NavRepository" Tag="repository" Content="Home">
                    <muxc:NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/home.svg" ShowAsMonochrome="True" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavPackages" Tag="packages" Content="Packages">
                    <muxc:NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/package.svg" ShowAsMonochrome="True" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavManifests" Tag="manifests" Content="Manifests">
                    <muxc:NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/list-checks.svg" ShowAsMonochrome="True" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavCatalogs" Tag="catalogs" Content="Catalogs">
                    <muxc:NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/library.svg" ShowAsMonochrome="True" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavGit" Tag="git" Content="Git">
                    <muxc:NavigationViewItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/git-branch.svg" ShowAsMonochrome="True" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
