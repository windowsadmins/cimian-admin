<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CimianAdmin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32" RowSpacing="16" ColumnSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
            Text="CimianAdmin"
            Style="{StaticResource TitleLargeTextBlockStyle}" />

        <TextBlock
            Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Text="Manage a Cimian deployment repository — open one to begin."
            Style="{StaticResource BodyTextBlockStyle}" />

        <TextBlock
            Grid.Row="2" Grid.Column="0"
            Text="Repository:"
            VerticalAlignment="Center" />
        <TextBox
            x:Name="RepositoryPathBox"
            Grid.Row="2" Grid.Column="1"
            PlaceholderText="C:\path\to\repository" />
        <Button
            Grid.Row="2" Grid.Column="2"
            Content="Browse..."
            Click="OnBrowseClicked" />

        <Button
            Grid.Row="3" Grid.Column="0"
            Content="Open Repository"
            Style="{StaticResource AccentButtonStyle}"
            Click="OnOpenClicked" />

        <ScrollViewer Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Auto">
            <TextBlock
                x:Name="StatusText"
                Text="No repository opened."
                TextWrapping="Wrap"
                FontFamily="Consolas" />
        </ScrollViewer>
    </Grid>
</Window>
