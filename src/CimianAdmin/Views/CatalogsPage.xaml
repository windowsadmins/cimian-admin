<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianAdmin.Views.CatalogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:catalogs="using:CimianAdmin.Core.Models.Catalogs"
    xmlns:packages="using:CimianAdmin.Core.Models.Packages"
    xmlns:nodes="using:CimianAdmin.Models"
    xmlns:local="using:CimianAdmin.Views">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Padding="16,12,8,16" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Catalogs"
                       Style="{StaticResource SubtitleTextBlockStyle}" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Compare" Click="OnCompareClicked" />
                <Button Content="Rebuild" Click="OnRebuildClicked" />
            </StackPanel>

            <ListView
                Grid.Row="2"
                ItemsSource="{x:Bind ViewModel.Catalogs, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedCatalog, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="catalogs:Catalog">
                        <StackPanel Padding="0,4,0,4">
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind PackageCount}" />
                                <Run Text=" packages" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <InfoBar
                Grid.Row="3"
                x:Name="StatusBar"
                IsClosable="False"
                IsOpen="False" />
        </Grid>

        <Border
            Grid.Column="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0"
                         x:Name="PackageSearchBox"
                         PlaceholderText="Search packages in this catalog"
                         Margin="20,12,20,4"
                         TextChanged="OnPackageSearchChanged" />
                <muxc:ProgressRing
                    Grid.Row="1"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="48"
                    Height="48" />
                <muxc:TreeView
                    Grid.Row="1"
                    x:Name="PackagesTree"
                    Padding="20,4,20,12"
                    SelectionMode="Single"
                    ItemInvoked="OnNodeInvoked">
                    <muxc:TreeView.ItemTemplate>
                        <DataTemplate x:DataType="nodes:PackageTreeNode">
                            <muxc:TreeViewItem
                                ItemsSource="{x:Bind Children}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                                <muxc:TreeViewItem.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Text="Open in package editor"
                                            Click="OnOpenPackageInMain"
                                            DataContext="{x:Bind}" />
                                        <MenuFlyoutItem
                                            Text="Open in new window"
                                            Click="OnOpenPackageInNewWindow"
                                            DataContext="{x:Bind}" />
                                    </MenuFlyout>
                                </muxc:TreeViewItem.ContextFlyout>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ImageIcon
                                        Grid.Column="0"
                                        Width="14" Height="14"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center">
                                        <ImageIcon.Source>
                                            <SvgImageSource UriSource="{x:Bind local:PackagesPage.NodeIconUri(HasPackage)}" />
                                        </ImageIcon.Source>
                                    </ImageIcon>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{x:Bind Package.Version, Mode=OneWay, FallbackValue=''}"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Margin="6,0,4,0"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </muxc:TreeViewItem>
                        </DataTemplate>
                    </muxc:TreeView.ItemTemplate>
                </muxc:TreeView>
            </Grid>
        </Border>
    </Grid>
</Page>
