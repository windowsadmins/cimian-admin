<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianAdmin.Views.CatalogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:catalogs="using:CimianAdmin.Core.Models.Catalogs"
    xmlns:packages="using:CimianAdmin.Core.Models.Packages"
    xmlns:nodes="using:CimianAdmin.Models"
    xmlns:local="using:CimianAdmin.Views">

    <Grid Padding="16,12,16,16" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Shadow="{StaticResource CardShadow}"
                Translation="0,0,16">
        <Grid Padding="16,12,16,16" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Catalogs"
                       Style="{StaticResource SubtitleTextBlockStyle}" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Compare" Click="OnCompareClicked" />
                <Button Content="Rebuild" Click="OnRebuildClicked" />
            </StackPanel>

            <ListView
                Grid.Row="2"
                ItemsSource="{x:Bind ViewModel.Catalogs, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedCatalog, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="catalogs:Catalog">
                        <StackPanel Padding="0,4,0,4">
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind PackageCount}" />
                                <Run Text=" packages" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <InfoBar
                Grid.Row="3"
                x:Name="StatusBar"
                IsClosable="False"
                IsOpen="False" />
        </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Style="{StaticResource CardStyle}"
            Shadow="{StaticResource CardShadow}"
            Translation="0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0"
                         x:Name="PackageSearchBox"
                         PlaceholderText="Search packages in this catalog"
                         Margin="20,12,20,4"
                         TextChanged="OnPackageSearchChanged" />
                <muxc:ProgressRing
                    Grid.Row="1"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="48"
                    Height="48" />
                <muxc:TreeView
                    Grid.Row="1"
                    x:Name="PackagesTree"
                    Padding="20,4,20,12"
                    SelectionMode="Single"
                    ItemInvoked="OnNodeInvoked">
                    <muxc:TreeView.ItemTemplate>
                        <DataTemplate x:DataType="nodes:PackageTreeNode">
                            <muxc:TreeViewItem
                                ItemsSource="{x:Bind Children}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                                <muxc:TreeViewItem.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Text="Open in package editor"
                                            Click="OnOpenPackageInMain"
                                            DataContext="{x:Bind}" />
                                        <MenuFlyoutItem
                                            Text="Open in new window"
                                            Click="OnOpenPackageInNewWindow"
                                            DataContext="{x:Bind}" />
                                    </MenuFlyout>
                                </muxc:TreeViewItem.ContextFlyout>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center">
                                        <Viewbox Visibility="{x:Bind local:PackagesPage.VisIfPackage(HasPackage)}">
                                            <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                                  Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Data="M7.5,4.27 L16.5,9.42 M21,8 A2,2 0 0 0 20,6.27 L13,2.27 A2,2 0 0 0 11,2.27 L4,6.27 A2,2 0 0 0 3,8 V16 A2,2 0 0 0 4,17.73 L11,21.73 A2,2 0 0 0 13,21.73 L20,17.73 A2,2 0 0 0 21,16 Z M3.3,7 L12,12 L20.7,7 M12,22 V12" />
                                        </Viewbox>
                                        <Viewbox Visibility="{x:Bind local:PackagesPage.VisIfFolder(HasPackage)}">
                                            <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                                  Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Data="M20,20 A2,2 0 0 0 22,18 V8 A2,2 0 0 0 20,6 H12.1 A2,2 0 0 1 10.41,5.1 L9.6,3.9 A2,2 0 0 0 7.93,3 H4 A2,2 0 0 0 2,5 V18 A2,2 0 0 0 4,20 Z" />
                                        </Viewbox>
                                    </Grid>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{x:Bind Package.Version, Mode=OneWay, FallbackValue=''}"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Margin="6,0,4,0"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </muxc:TreeViewItem>
                        </DataTemplate>
                    </muxc:TreeView.ItemTemplate>
                </muxc:TreeView>
            </Grid>
        </Border>
    </Grid>
</Page>
