<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianAdmin.Views.GitPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    KeyboardAcceleratorPlacementMode="Hidden">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Modifiers="Control" Key="A" Invoked="OnSelectAllAccelerator" />
        <KeyboardAccelerator Modifiers="Control,Shift" Key="A" Invoked="OnSelectNoneAccelerator" />
        <KeyboardAccelerator Modifiers="Control" Key="Enter" Invoked="OnCommitAccelerator" />
        <KeyboardAccelerator Key="F5" Invoked="OnRefreshAccelerator" />
        <KeyboardAccelerator Key="Space" Invoked="OnSpaceAccelerator" />
    </Page.KeyboardAccelerators>

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: branch picker + scope + refresh -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Git"
                           Style="{StaticResource TitleLargeTextBlockStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ImageIcon Height="16" Width="16"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center">
                        <ImageIcon.Source>
                            <SvgImageSource UriSource="ms-appx:///Assets/git-branch.svg" />
                        </ImageIcon.Source>
                    </ImageIcon>
                    <TextBlock Text="Branch:" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="BranchPicker"
                              MinWidth="220"
                              SelectionChanged="OnBranchSelectionChanged" />
                    <TextBlock x:Name="AheadBehindText"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBlock x:Name="ScopeLine"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="HelpButton" Click="OnHelpClicked" Width="36">
                    <Button.Content>
                        <ImageIcon Width="14" Height="14">
                            <ImageIcon.Source>
                                <SvgImageSource UriSource="ms-appx:///Assets/circle-help.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </Button.Content>
                    <ToolTipService.ToolTip>
                        <TextBlock Text="Keyboard shortcuts (?)" />
                    </ToolTipService.ToolTip>
                </Button>
                <Button x:Name="RefreshButton" Content="Refresh" Click="OnRefreshClicked">
                    <ToolTipService.ToolTip>
                        <TextBlock Text="Refresh (r or F5)" />
                    </ToolTipService.ToolTip>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Two-pane body: changes list + draggable splitter + diff -->
        <Grid Grid.Row="1" x:Name="BodyGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="240" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="3*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" MinHeight="36" VerticalAlignment="Center">
                    <TextBlock x:Name="ChangesHeader"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button x:Name="SelectAllButton" Content="Select all" Click="OnSelectAllClicked">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Toggle all (a) — Ctrl+A also" />
                        </ToolTipService.ToolTip>
                    </Button>
                    <Button x:Name="SelectNoneButton" Content="Clear" Click="OnSelectNoneClicked">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Clear selection (Ctrl+Shift+A)" />
                        </ToolTipService.ToolTip>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                    <Grid>
                        <ListView x:Name="ChangesList"
                                  SelectionMode="Single"
                                  IsItemClickEnabled="True"
                                  ItemClick="OnChangeItemClicked"
                                  SelectionChanged="OnChangeSelectionChanged"
                                  KeyDown="OnChangesListKeyDown"
                                  Padding="6" />
                        <TextBlock x:Name="EmptyState"
                                   Text="Working tree clean — no changes to commit."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="NoGitState"
                                   Text="No git repository detected for this Cimian deployment."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Spacing="6">
                    <TextBlock Text="Subject (≤72 chars recommended)"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox x:Name="SubjectBox"
                             PlaceholderText="Promote Office 2025 to Production"
                             TextChanged="OnSubjectChanged" />
                    <TextBlock Text="Body (optional)"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Margin="0,4,0,0" />
                    <TextBox x:Name="BodyBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Mono, Consolas"
                             MinHeight="64"
                             MaxHeight="140" />
                </StackPanel>

                <Grid Grid.Row="3" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <ImageIcon Width="12" Height="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center">
                            <ImageIcon.Source>
                                <SvgImageSource UriSource="ms-appx:///Assets/user.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                        <TextBlock x:Name="IdentityText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280"
                                   Text="(no identity)" />
                        <HyperlinkButton x:Name="EditIdentityButton"
                                         Content="Edit"
                                         Padding="4,0,4,0"
                                         Click="OnEditIdentityClicked" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Right">
                        <Button x:Name="CommitButton"
                                Content="Commit"
                                IsEnabled="False"
                                Click="OnCommitClicked">
                            <ToolTipService.ToolTip>
                                <TextBlock Text="Commit selected files (Ctrl+Enter)" />
                            </ToolTipService.ToolTip>
                        </Button>
                        <Button x:Name="CommitPushButton"
                                Content="Commit &amp; push"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="False"
                                Click="OnCommitPushClicked" />
                        <Button x:Name="CommitOverflowButton"
                                IsEnabled="False"
                                Width="36">
                            <Button.Content>
                                <ImageIcon Width="14" Height="14">
                                    <ImageIcon.Source>
                                        <SvgImageSource UriSource="ms-appx:///Assets/more-horizontal.svg" />
                                    </ImageIcon.Source>
                                </ImageIcon>
                            </Button.Content>
                            <ToolTipService.ToolTip>
                                <TextBlock Text="More commit options" />
                            </ToolTipService.ToolTip>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuFlyoutItem x:Name="CommitNoVerifyItem"
                                                    Text="Commit without hooks (--no-verify)"
                                                    Click="OnCommitNoVerifyClicked" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <controls:GridSplitter Grid.Column="1"
                                   Width="6"
                                   Background="Transparent"
                                   ResizeBehavior="PreviousAndNext"
                                   ResizeDirection="Columns" />

            <Grid Grid.Column="2" RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8" MinHeight="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="DiffHeader"
                               Text="Diff"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <HyperlinkButton Grid.Column="1"
                                     x:Name="OpenInEditorButton"
                                     Content="Open in editor"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Center"
                                     Click="OnOpenInEditorClicked">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Open in editor (o)" />
                        </ToolTipService.ToolTip>
                    </HyperlinkButton>
                </Grid>

                <Border Grid.Row="1"
                        Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                    <Grid>
                        <ScrollViewer x:Name="DiffScroller"
                                      HorizontalScrollMode="Enabled"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="10">
                            <TextBlock x:Name="DiffText"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="12"
                                       TextWrapping="NoWrap"
                                       IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                        <TextBlock x:Name="DiffPlaceholder"
                                   Text="Select a changed file to see its diff."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <InfoBar x:Name="ResultBar"
                     IsClosable="True"
                     IsOpen="False" />

            <!-- Live progress overlay: appears whenever a git operation is running so
                 the app never sits silently while hooks/network do their thing. -->
            <Border x:Name="ProgressOverlay"
                    Visibility="Collapsed"
                    Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16"
                    Padding="12,10,12,10">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <ProgressRing x:Name="ProgressRing" IsActive="True" Width="18" Height="18" />
                        <TextBlock x:Name="ProgressTitle"
                                   Text="Running…"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Row="1"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="ProgressScroller"
                                      MaxHeight="120"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="8,6,8,6">
                            <TextBlock x:Name="ProgressText"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="11"
                                       TextWrapping="NoWrap"
                                       IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
