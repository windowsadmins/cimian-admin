<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianAdmin.Views.Import.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CimianAdmin.Views">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Import"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />
            <TextBlock Text="Drop installers (MSI / EXE / NUPKG / MSIX) anywhere on this page to start the cimiimport wizard."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border x:Name="IdleView"
                Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Shadow="{StaticResource CardShadow}"
                Translation="0,0,16"
                AllowDrop="True"
                DragOver="OnDropZoneDragOver"
                Drop="OnDropZoneDrop">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <Viewbox Width="48" Height="48">
                        <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                              Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                              Data="M21,15 V19 A2,2 0 0 1 19,21 H5 A2,2 0 0 1 3,19 V15 M17,8 L12,3 L7,8 M12,3 V15" />
                    </Viewbox>
                    <TextBlock Text="Drop installer files here"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <Button x:Name="PickFileButton"
                            Content="Or pick a file…"
                            HorizontalAlignment="Center"
                            Click="OnPickFileClicked" />
                    <TextBlock x:Name="StatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="420"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="WizardView" Grid.Row="1" Visibility="Collapsed" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="WizardStepLabel"
                           Text="Step 1 of 4 · Review"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           x:Name="WizardFileName"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <HyperlinkButton Grid.Column="2"
                                 Content="Pick a different file…"
                                 Click="OnRestartClicked" />
            </Grid>

            <!-- Step body card. Each step swaps in a different panel via code-behind. -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Shadow="{StaticResource CardShadow}"
                    Translation="0,0,16"
                    Padding="20,16,20,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <!-- Step 1: detected facts + template match. -->
                        <StackPanel x:Name="Step1Panel" Spacing="16">
                            <InfoBar x:Name="TemplateBanner"
                                     IsClosable="False"
                                     IsOpen="False"
                                     Severity="Informational">
                                <InfoBar.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                        <Button x:Name="UseTemplateButton"
                                                Content="Use template"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Click="OnUseTemplateClicked" />
                                        <Button x:Name="StartFreshButton"
                                                Content="Start fresh"
                                                Click="OnStartFreshClicked" />
                                    </StackPanel>
                                </InfoBar.Content>
                            </InfoBar>

                            <TextBlock Text="Detected metadata"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />

                            <Grid x:Name="DetectedGrid" ColumnSpacing="20" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                            </Grid>

                            <TextBlock x:Name="ExtractError"
                                       Visibility="Collapsed"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Step 2: edit detected metadata. Hidden until the user advances. -->
                        <StackPanel x:Name="Step2Panel" Spacing="14" Visibility="Collapsed">
                            <TextBlock Text="Edit metadata"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Adjust anything the extractor got wrong. Architecture and identity codes are read-only because they're sourced from the installer file."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <Grid ColumnSpacing="12" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Name" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox x:Name="NameBox" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Version" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox x:Name="VersionBox" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Developer" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox x:Name="DeveloperBox" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Category" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox x:Name="CategoryBox" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Architecture" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <ComboBox x:Name="ArchCombo" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="x64" Tag="x64" />
                                        <ComboBoxItem Content="arm64" Tag="arm64" />
                                        <ComboBoxItem Content="x64 + arm64" Tag="x64,arm64" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <CheckBox x:Name="UnattendedInstallCheck" Content="Unattended install" />
                                    <CheckBox x:Name="UnattendedUninstallCheck" Content="Unattended uninstall" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Description" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="DescriptionBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Catalogs" Style="{StaticResource CaptionTextBlockStyle}" />
                                <local:ChipListPicker x:Name="CatalogsPicker"
                                                       PlaceholderText="Add a catalog…" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Blocking applications" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock Text="Apps that must be closed before the install runs. Suggestions come from the existing package list."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <local:ChipListPicker x:Name="BlockingPicker"
                                                       PlaceholderText="Add a blocking app…" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        x:Name="BackButton"
                        Content="Back"
                        Visibility="Collapsed"
                        Click="OnBackClicked" />
                <Button Grid.Column="2" Content="Cancel" Click="OnCancelClicked" />
                <Button Grid.Column="3"
                        x:Name="ContinueButton"
                        Content="Continue"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="False"
                        Click="OnContinueClicked" />
            </Grid>
        </Grid>
    </Grid>
</Page>
