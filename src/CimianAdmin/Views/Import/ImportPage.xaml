<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianAdmin.Views.Import.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Import"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />
            <TextBlock Text="Drop installers (MSI / EXE / NUPKG / MSIX) anywhere on this page to start the cimiimport wizard."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border x:Name="IdleView"
                Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Shadow="{StaticResource CardShadow}"
                Translation="0,0,16"
                AllowDrop="True"
                DragOver="OnDropZoneDragOver"
                Drop="OnDropZoneDrop">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <Viewbox Width="48" Height="48">
                        <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                              Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                              Data="M21,15 V19 A2,2 0 0 1 19,21 H5 A2,2 0 0 1 3,19 V15 M17,8 L12,3 L7,8 M12,3 V15" />
                    </Viewbox>
                    <TextBlock Text="Drop installer files here"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <Button x:Name="PickFileButton"
                            Content="Or pick a file…"
                            HorizontalAlignment="Center"
                            Click="OnPickFileClicked" />
                    <TextBlock x:Name="StatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="420"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="WizardView" Grid.Row="1" Visibility="Collapsed" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Step 1 of 4 · Review"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           x:Name="WizardFileName"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <HyperlinkButton Grid.Column="2"
                                 Content="Pick a different file…"
                                 Click="OnRestartClicked" />
            </Grid>

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Shadow="{StaticResource CardShadow}"
                    Translation="0,0,16"
                    Padding="20,16,20,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <InfoBar x:Name="TemplateBanner"
                                 IsClosable="False"
                                 IsOpen="False"
                                 Severity="Informational">
                            <InfoBar.Content>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <Button x:Name="UseTemplateButton"
                                            Content="Use template"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="OnUseTemplateClicked" />
                                    <Button x:Name="StartFreshButton"
                                            Content="Start fresh"
                                            Click="OnStartFreshClicked" />
                                </StackPanel>
                            </InfoBar.Content>
                        </InfoBar>

                        <TextBlock Text="Detected metadata"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <Grid x:Name="DetectedGrid" ColumnSpacing="20" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                        </Grid>

                        <TextBlock x:Name="ExtractError"
                                   Visibility="Collapsed"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Cancel" Click="OnCancelClicked" />
                <Button Grid.Column="2"
                        x:Name="ContinueButton"
                        Content="Continue"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="False"
                        Click="OnContinueClicked">
                    <ToolTipService.ToolTip>
                        <TextBlock Text="Step 2 (edit metadata) lands in M4." />
                    </ToolTipService.ToolTip>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>
