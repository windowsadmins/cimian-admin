<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CimianAdmin.Views.ManifestEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:CimianAdmin.Views">

    <Grid>
        <TextBlock
            x:Name="EmptyState"
            Text="Select a manifest to view or edit its details."
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <Grid x:Name="EditorRoot" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="20,16,20,12" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock x:Name="DisplayNameText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="NameText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="FilePathText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="DiskChangedIndicator"
                               Text="Modified on disk"
                               Visibility="Collapsed"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               VerticalAlignment="Center">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="This file differs from HEAD in the git working tree." />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <TextBlock x:Name="DirtyIndicator"
                               Text="Modified"
                               Visibility="Collapsed"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                               VerticalAlignment="Center" />
                    <Button x:Name="DeleteButton" Click="OnDeleteClicked">
                        <Button.Content>
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        </Button.Content>
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Delete this manifest" />
                        </ToolTipService.ToolTip>
                    </Button>
                    <Button x:Name="RevertButton" Content="Revert" IsEnabled="False" Click="OnRevertClicked" />
                    <Button x:Name="SaveButton"
                            Content="Save"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="False"
                            Click="OnSaveClicked" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Padding="20,0,20,20">
                <StackPanel Spacing="24">

                    <!-- General (catalogs first, then included manifests, then display name) -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="General" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <StackPanel>
                            <TextBlock Text="Catalogs" Style="{StaticResource CaptionTextBlockStyle}" />
                            <StackPanel x:Name="CatalogsContainer" Orientation="Horizontal" Spacing="14"
                                        Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Included manifests" Style="{StaticResource CaptionTextBlockStyle}" />
                            <Grid x:Name="IncludedHeaderRow" ColumnSpacing="8" Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text=" " />
                                <TextBlock Grid.Column="1"
                                           Text="Conditionals"
                                           MinWidth="180"
                                           Margin="0,0,32,0"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                            <local:ContextualChipList x:Name="IncludedPicker"
                                                      PlaceholderText=""
                                                      Changed="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Display name" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBox x:Name="DisplayNameField" TextChanged="OnFieldChanged" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Managed -->
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Managed" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <HyperlinkButton Grid.Column="1"
                                             x:Name="AddConditionalButton"
                                             Content="Add conditional"
                                             Click="OnAddConditionalClicked"
                                             Padding="4,2,4,2"
                                             Margin="0,0,12,0" />
                            <TextBlock x:Name="ManagedConditionalHeader"
                                       Grid.Column="2"
                                       Text="Conditionals"
                                       MinWidth="180"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,32,0"
                                       VerticalAlignment="Bottom" />
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="Managed installs" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ContextualChipList x:Name="ManagedInstallsPicker"
                                                      PlaceholderText=""
                                                      Changed="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Managed uninstalls" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ContextualChipList x:Name="ManagedUninstallsPicker"
                                                      PlaceholderText=""
                                                      Changed="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Managed updates" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ContextualChipList x:Name="ManagedUpdatesPicker"
                                                      PlaceholderText=""
                                                      Changed="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Optional installs" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ContextualChipList x:Name="OptionalInstallsPicker"
                                                      PlaceholderText=""
                                                      Changed="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Default installs" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ChipListPicker x:Name="DefaultInstallsPicker"
                                                  PlaceholderText=""
                                                  Changed="OnFieldChanged" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Notes -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Notes" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBox x:Name="NotesField"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                 TextChanged="OnFieldChanged" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <InfoBar Grid.Row="2"
                     x:Name="StatusBar"
                     IsClosable="True"
                     IsOpen="False" />
        </Grid>
    </Grid>
</UserControl>
