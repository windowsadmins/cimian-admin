<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CimianAdmin.Views.PackageEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:CimianAdmin.Views">

    <Grid x:Name="RootGrid">
        <TextBlock
            x:Name="EmptyState"
            Text="Select a package to view or edit its details."
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <Grid x:Name="EditorRoot" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="20,16,20,12" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock x:Name="DisplayNameText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="VersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="FilePathText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="DiskChangedIndicator"
                               Text="Modified on disk"
                               Visibility="Collapsed"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               VerticalAlignment="Center">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="This file differs from HEAD in the git working tree." />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <TextBlock x:Name="DirtyIndicator"
                               Text="Modified"
                               Visibility="Collapsed"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                               VerticalAlignment="Center" />
                    <Button x:Name="DeleteButton" Click="OnDeleteClicked">
                        <Button.Content>
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        </Button.Content>
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Delete this pkginfo file" />
                        </ToolTipService.ToolTip>
                    </Button>
                    <Button x:Name="RevertButton" Content="Revert" IsEnabled="False" Click="OnRevertClicked" />
                    <Button x:Name="SaveButton"
                            Content="Save"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="False"
                            Click="OnSaveClicked" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Padding="20,0,20,20">
                <StackPanel Spacing="24">

                    <!-- General -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="General" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Name" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="NameField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Version" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="VersionField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Display name" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="DisplayNameField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Icon name" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="IconNameField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Developer" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="DeveloperField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Category" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="CategoryField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="Description" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBox x:Name="DescriptionField"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60"
                                     TextChanged="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Catalogs" Style="{StaticResource CaptionTextBlockStyle}" />
                            <StackPanel x:Name="CatalogsContainer" Orientation="Horizontal" Spacing="14"
                                        Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Installer (smart by type) -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Installer" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Type" Style="{StaticResource CaptionTextBlockStyle}" />
                                <ComboBox x:Name="InstallerTypeBox"
                                          IsEditable="True"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="OnInstallerTypeChanged"
                                          TextSubmitted="OnInstallerTypeSubmitted"
                                          DropDownClosed="OnInstallerTypeDropDownClosed"
                                          LostFocus="OnInstallerTypeLostFocus">
                                    <x:String>msi</x:String>
                                    <x:String>msix</x:String>
                                    <x:String>exe</x:String>
                                    <x:String>ps1</x:String>
                                    <x:String>nupkg</x:String>
                                    <x:String>bat</x:String>
                                    <x:String>cmd</x:String>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Location" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="InstallerLocationField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Size (bytes)" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="InstallerSizeField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="Hash (sha256)" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBox x:Name="InstallerHashField" FontFamily="Consolas" TextChanged="OnFieldChanged" />
                        </StackPanel>
                        <Grid x:Name="InstallerArgsRow" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" x:Name="InstallerArgsPanel">
                                <TextBlock Text="Arguments (one per line)" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="InstallerArgsField"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                         FontFamily="Consolas" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" x:Name="InstallerSwitchesPanel">
                                <TextBlock Text="Switches (one per line)" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="InstallerSwitchesField"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                         FontFamily="Consolas" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" x:Name="InstallerFlagsPanel">
                                <TextBlock Text="Flags (one per line)" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="InstallerFlagsField"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                         FontFamily="Consolas" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="InstallerExtraRow" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" x:Name="InstallerSubcommandPanel">
                                <TextBlock Text="Subcommand" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="InstallerSubcommandField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" x:Name="InstallerTempDirPanel">
                                <TextBlock Text="Temp dir" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="InstallerTempDirField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Behavior -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Behavior" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="UnattendedInstallBox" Content="Unattended install" Click="OnFieldChanged" />
                            <CheckBox Grid.Column="1" x:Name="UnattendedUninstallBox" Content="Unattended uninstall" Click="OnFieldChanged" />
                            <CheckBox Grid.Column="2" x:Name="UninstallableBox" Content="Uninstallable" Click="OnFieldChanged" />
                            <CheckBox Grid.Column="3" x:Name="OnDemandBox" Content="On demand" Click="OnFieldChanged" />
                        </Grid>
                        <TextBlock Text="Install window"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start (HH:MM)" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="WindowStartField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="End (HH:MM)" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="WindowEndField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Weekdays (e.g. Mon, Tue)" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="WindowWeekdaysField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Requirements -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Requirements" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Min OS version" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="MinOsField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Max OS version" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="MaxOsField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Min Cimian version" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBox x:Name="MinCimianField" TextChanged="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="Supported architectures" Style="{StaticResource CaptionTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                <CheckBox x:Name="ArchX64Box" Content="x64" Click="OnFieldChanged" />
                                <CheckBox x:Name="ArchArm64Box" Content="arm64" Click="OnFieldChanged" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Blocking applications" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ChipListPicker x:Name="BlockingPicker"
                                                  PlaceholderText="Type an .exe name and press Enter"
                                                  Changed="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Requires" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ChipListPicker x:Name="RequiresPicker"
                                                  PlaceholderText="Search packages..."
                                                  Changed="OnFieldChanged" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Update for" Style="{StaticResource CaptionTextBlockStyle}" />
                            <local:ChipListPicker x:Name="UpdateForPicker"
                                                  PlaceholderText="Search packages..."
                                                  Changed="OnFieldChanged" />
                        </StackPanel>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Managed profiles" Style="{StaticResource CaptionTextBlockStyle}" />
                                <local:ChipListPicker x:Name="ManagedProfilesPicker"
                                                      PlaceholderText="Type a profile name and press Enter"
                                                      Changed="OnFieldChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Managed apps" Style="{StaticResource CaptionTextBlockStyle}" />
                                <local:ChipListPicker x:Name="ManagedAppsPicker"
                                                      PlaceholderText="Search packages, or press Enter to add a custom name"
                                                      Changed="OnFieldChanged" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Detection (editable) -->
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection (installs)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Button Grid.Column="1" Content="Add install rule" Click="OnAddInstallClicked" />
                        </Grid>
                        <StackPanel x:Name="InstallsContainer" Spacing="8" />
                        <TextBlock x:Name="NoInstallsText"
                                   Text="No detection rules."
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Visibility="Collapsed" />
                    </StackPanel>

                    <!-- Uninstaller -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Uninstaller" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <StackPanel>
                            <TextBlock Text="Uninstaller path" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBox x:Name="UninstallerPathField" TextChanged="OnFieldChanged" />
                        </StackPanel>
                        <TextBlock x:Name="UninstallerSummaryLabel"
                                   Text="Uninstall operations (read-only — edit YAML directly for advanced cases)"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ItemsControl x:Name="UninstallerSummary">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,2,0,2">
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Consolas" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Scripts (50/50 layout, double height) -->
                    <StackPanel Spacing="14">
                        <TextBlock Text="Scripts" Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <TextBlock Text="Install" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <local:ScriptEditor x:Name="InstallCheckScriptEditor"
                                            Label="installcheck_script"
                                            Height="240"
                                            ScriptChanged="OnFieldChanged" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <local:ScriptEditor Grid.Column="0" x:Name="PreinstallScriptEditor"
                                                Label="preinstall_script"
                                                Height="240"
                                                ScriptChanged="OnFieldChanged" />
                            <local:ScriptEditor Grid.Column="1" x:Name="PostinstallScriptEditor"
                                                Label="postinstall_script"
                                                Height="240"
                                                ScriptChanged="OnFieldChanged" />
                        </Grid>

                        <TextBlock Text="Uninstall" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,8,0,0" />
                        <local:ScriptEditor x:Name="UninstallCheckScriptEditor"
                                            Label="uninstallcheck_script"
                                            Height="240"
                                            ScriptChanged="OnFieldChanged" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <local:ScriptEditor Grid.Column="0" x:Name="PreuninstallScriptEditor"
                                                Label="preuninstall_script"
                                                Height="240"
                                                ScriptChanged="OnFieldChanged" />
                            <local:ScriptEditor Grid.Column="1" x:Name="PostuninstallScriptEditor"
                                                Label="postuninstall_script"
                                                Height="240"
                                                ScriptChanged="OnFieldChanged" />
                        </Grid>
                    </StackPanel>

                    <!-- Trailing _metadata (read-only summary) -->
                    <StackPanel Spacing="10" x:Name="MetadataSection" Visibility="Collapsed">
                        <TextBlock Text="_metadata" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="MetadataText"
                                   FontFamily="Consolas"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <InfoBar Grid.Row="2"
                     x:Name="StatusBar"
                     IsClosable="True"
                     IsOpen="False" />
        </Grid>
    </Grid>
</UserControl>
