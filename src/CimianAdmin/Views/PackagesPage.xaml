<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianAdmin.Views.PackagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:nodes="using:CimianAdmin.Models"
    xmlns:local="using:CimianAdmin.Views">

    <Grid Padding="16,12,16,16" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Shadow="{StaticResource CardShadow}"
                Translation="0,0,16">
        <Grid Padding="16,16,16,16" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Packages" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBox
                Grid.Row="1"
                PlaceholderText="Search packages"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Row="2"
                x:Name="CountText"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <muxc:TreeView
                Grid.Row="3"
                x:Name="PackagesTree"
                ItemsSource="{x:Bind ViewModel.RootNodes, Mode=OneWay}"
                ItemInvoked="OnNodeInvoked"
                SelectionMode="Single">
                <muxc:TreeView.ItemTemplate>
                    <DataTemplate x:DataType="nodes:PackageTreeNode">
                        <muxc:TreeViewItem
                            ItemsSource="{x:Bind Children}"
                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                            <muxc:TreeViewItem.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        Text="Open in new window"
                                        Click="OnOpenInNewWindow"
                                        DataContext="{x:Bind}" />
                                </MenuFlyout>
                            </muxc:TreeViewItem.ContextFlyout>
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ImageIcon
                                    Grid.Column="0"
                                    Width="14" Height="14"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center">
                                    <ImageIcon.Source>
                                        <SvgImageSource UriSource="{x:Bind local:PackagesPage.NodeIconUri(HasPackage)}" />
                                    </ImageIcon.Source>
                                </ImageIcon>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind Package.Version, Mode=OneWay, FallbackValue=''}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Margin="6,0,4,0"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </muxc:TreeViewItem>
                    </DataTemplate>
                </muxc:TreeView.ItemTemplate>
            </muxc:TreeView>
        </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Style="{StaticResource CardStyle}"
            Shadow="{StaticResource CardShadow}"
            Translation="0,0,16">
            <Grid>
                <muxc:ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="48"
                    Height="48" />
                <local:PackageEditor x:Name="Editor" />
            </Grid>
        </Border>
    </Grid>
</Page>
