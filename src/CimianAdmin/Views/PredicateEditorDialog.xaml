<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CimianAdmin.Views.PredicateEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Condition"
    PrimaryButtonText="OK"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">800</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">600</x:Double>
    </ContentDialog.Resources>

    <Grid Width="720" Height="440" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Tab pill -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <ToggleButton x:Name="PredicateTabButton"
                          Content="Predicate Editor"
                          IsChecked="True"
                          Click="OnPredicateTabClicked" />
            <ToggleButton x:Name="CustomTabButton"
                          Content="Custom"
                          Click="OnCustomTabClicked" />
        </StackPanel>

        <!-- Predicate editor tab -->
        <Grid Grid.Row="1" x:Name="PredicateTab" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ComboBox x:Name="CompoundPicker"
                          MinWidth="80"
                          SelectionChanged="OnCompoundChanged">
                    <ComboBoxItem Content="All" Tag="All" />
                    <ComboBoxItem Content="Any" Tag="Any" />
                    <ComboBoxItem Content="None" Tag="None" />
                </ComboBox>
                <TextBlock Text="of the following are true"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="RowsHost" Spacing="6" Padding="8" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Custom tab -->
        <Grid Grid.Row="1" x:Name="CustomTab" Visibility="Collapsed">
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="2">
                <TextBox x:Name="CustomTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Mono, Consolas"
                         BorderThickness="0"
                         PlaceholderText="hostname == 'MAC-123' AND os_vers_major >= 11" />
            </Border>
        </Grid>
    </Grid>
</ContentDialog>
