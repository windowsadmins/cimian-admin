<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianAdmin.Views.RepositoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <DataTemplate x:Key="RecentRowTemplate" x:DataType="x:String">
            <TextBlock Text="{x:Bind}" TextTrimming="CharacterEllipsis" Padding="4,2,4,2" />
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="32" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock
                    x:Name="RepoNameText"
                    Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock
                    x:Name="RepoPathText"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <ItemsControl
                Grid.Row="1"
                x:Name="StatsHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="16" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Grid Grid.Row="2" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16,20,12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Recently modified pkginfo"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <ListView x:Name="RecentPackagesList"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="OnRecentPackageClicked"
                                  MaxHeight="220"
                                  ItemTemplate="{StaticResource RecentRowTemplate}" />
                        <TextBlock x:Name="NoRecentPackagesText"
                                   Text="No recently modified packages."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16,20,12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Recently modified manifests"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <ListView x:Name="RecentManifestsList"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="OnRecentManifestClicked"
                                  MaxHeight="220"
                                  ItemTemplate="{StaticResource RecentRowTemplate}" />
                        <TextBlock x:Name="NoRecentManifestsText"
                                   Text="No recently modified manifests."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>

            <Button
                Grid.Row="3"
                Content="Validate repository"
                Click="OnValidateClicked"
                HorizontalAlignment="Left" />

            <InfoBar
                Grid.Row="4"
                x:Name="ValidationBar"
                IsClosable="False"
                IsOpen="False" />

            <ScrollViewer Grid.Row="5" MaxHeight="240">
                <ItemsControl x:Name="ValidationDetails">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}" TextWrapping="Wrap" Margin="0,2,0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </ScrollViewer>
</Page>
