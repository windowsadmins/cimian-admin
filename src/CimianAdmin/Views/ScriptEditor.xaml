<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CimianAdmin.Views.ScriptEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="6" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LabelText"
                       Grid.Column="0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    x:Name="ExpandButton"
                    Click="OnExpandClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,2,6,2"
                    MinWidth="0"
                    Visibility="Visible">
                <FontIcon Glyph="&#xE740;" FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ToolTipService.ToolTip>
                    <TextBlock Text="Open in full editor" />
                </ToolTipService.ToolTip>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Gutter: a clipped strip whose inner TextBlock translates to mirror
                     the RichEditBox's vertical scroll. Width set in code so it fits the
                     widest line number. -->
                <Border Grid.Column="0"
                        x:Name="GutterClip"
                        Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,1,0">
                    <Border.Clip>
                        <RectangleGeometry x:Name="GutterClipGeometry" />
                    </Border.Clip>
                    <TextBlock x:Name="LineNumbers"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Padding="8,8,8,8"
                               TextAlignment="Right"
                               IsHitTestVisible="False">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="GutterScroll" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Border>

                <RichEditBox Grid.Column="1"
                             x:Name="Editor"
                             AcceptsReturn="True"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="13"
                             BorderThickness="0"
                             Padding="8"
                             IsSpellCheckEnabled="False"
                             IsTextPredictionEnabled="False"
                             ClipboardCopyFormat="PlainText"
                             TextWrapping="NoWrap"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="OnTextChanged"
                             Loaded="OnEditorLoaded"
                             SizeChanged="OnEditorSizeChanged" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
