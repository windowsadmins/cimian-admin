<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CimianStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="40"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Column 3 historically held a title-bar icon; removed by user request. -->


            <Button x:Name="BackButton"
                    Grid.Column="1"
                    Click="OnBackClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="36" Height="32"
                    Margin="0,0,2,0"
                    IsEnabled="False">
                <Viewbox Width="14" Height="14">
                    <Path Width="24" Height="24" Style="{StaticResource LucidePath}" Data="M12,19 L5,12 L12,5 M19,12 L5,12" />
                </Viewbox>
                <ToolTipService.ToolTip>
                    <TextBlock Text="Back" />
                </ToolTipService.ToolTip>
            </Button>
            <Button x:Name="ForwardButton"
                    Grid.Column="2"
                    Click="OnForwardClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="36" Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="False">
                <Viewbox Width="14" Height="14">
                    <Path Width="24" Height="24" Style="{StaticResource LucidePath}" Data="M5,12 L19,12 M12,5 L19,12 L12,19" />
                </Viewbox>
                <ToolTipService.ToolTip>
                    <TextBlock Text="Forward" />
                </ToolTipService.ToolTip>
            </Button>

            <TextBlock x:Name="AppTitleText"
                       Grid.Column="4"
                       Text="CimianStudio"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="5"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        Margin="0,0,140,0">
                <Button x:Name="SaveAllButton"
                        Visibility="Collapsed"
                        Click="OnSaveAllClicked"
                        Padding="10,4"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                            <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                  Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                                  Data="M19,21 H5 A2,2 0 0 1 3,19 V5 A2,2 0 0 1 5,3 H16 L21,8 V19 A2,2 0 0 1 19,21 Z M17,21 V13 H7 V21 M7,3 V8 H15" />
                        </Viewbox>
                        <TextBlock x:Name="SaveAllText"
                                   Text="Save all"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ToolTipService.ToolTip>
                        <TextBlock x:Name="SaveAllTooltip" Text="Save all pending edits to disk" />
                    </ToolTipService.ToolTip>
                </Button>
                <TextBlock x:Name="RepoTitleText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="360" />
                <Border x:Name="GitIndicator"
                        Visibility="Collapsed"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,2,8,2"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                            <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                  Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                  Data="M6,3 V15 M15,6 A3,3 0 1 0 21,6 A3,3 0 1 0 15,6 Z M3,18 A3,3 0 1 0 9,18 A3,3 0 1 0 3,18 Z M18,9 A9,9 0 0 1 9,18" />
                        </Viewbox>
                        <TextBlock x:Name="GitBranchText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="GitAheadBehindText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ToolTipService.ToolTip>
                        <TextBlock x:Name="GitIndicatorTooltip" />
                    </ToolTipService.ToolTip>
                </Border>
            </StackPanel>
        </Grid>

        <muxc:NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            CompactPaneLength="48"
            OpenPaneLength="240"
            SelectionChanged="NavView_SelectionChanged">

            <muxc:NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            </muxc:NavigationView.Resources>

            <muxc:NavigationView.MenuItems>
                <!-- Nav rail icons are PathIcon (an IconElement subclass that fills with
                     Foreground, so theme-aware). Path data is from Fluent UI System Icons
                     (Microsoft's open-source library) — each is a single-path SVG whose
                     interior is punched out via the NonZero fill rule, producing an
                     outlined appearance when rendered filled. Matches Win11 Fluent design. -->
                <muxc:NavigationViewItem x:Name="NavRepository" Tag="repository" Content="Dashboard">
                    <muxc:NavigationViewItem.Icon>
                        <PathIcon Data="M10.5495 2.53189C11.3874 1.82531 12.6126 1.82531 13.4505 2.5319L20.2005 8.224C20.7074 8.65152 21 9.2809 21 9.94406L21 19.2539C21 20.2204 20.2165 21.0039 19.25 21.0039H15.75C14.7835 21.0039 14 20.2204 14 19.2539L14 14.2468C14 14.1088 13.8881 13.9968 13.75 13.9968H10.25C10.1119 13.9968 9.99999 14.1088 9.99999 14.2468L9.99999 19.2539C9.99999 20.2204 9.2165 21.0039 8.25 21.0039H4.75C3.7835 21.0039 3 20.2204 3 19.2539V9.94406C3 9.2809 3.29255 8.65152 3.79952 8.224L10.5495 2.53189ZM12.4835 3.6786C12.2042 3.44307 11.7958 3.44307 11.5165 3.6786L4.76651 9.37071C4.59752 9.51321 4.5 9.72301 4.5 9.94406L4.5 19.2539C4.5 19.392 4.61193 19.5039 4.75 19.5039H8.25C8.38807 19.5039 8.49999 19.392 8.49999 19.2539L8.49999 14.2468C8.49999 13.2803 9.2835 12.4968 10.25 12.4968H13.75C14.7165 12.4968 15.5 13.2803 15.5 14.2468L15.5 19.2539C15.5 19.392 15.6119 19.5039 15.75 19.5039H19.25C19.3881 19.5039 19.5 19.392 19.5 19.2539L19.5 9.94406C19.5 9.72301 19.4025 9.51321 19.2335 9.37071L12.4835 3.6786Z" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavPackages" Tag="packages" Content="Packages">
                    <muxc:NavigationViewItem.Icon>
                        <PathIcon Data="M10.5911 2.51301C11.4947 2.14671 12.5053 2.14671 13.4089 2.51301L20.9075 5.55298C21.5679 5.82071 22 6.46216 22 7.17477V16.8275C22 17.5401 21.5679 18.1815 20.9075 18.4493L13.4089 21.4892C12.5053 21.8555 11.4947 21.8555 10.5911 21.4892L3.09252 18.4493C2.43211 18.1815 2 17.5401 2 16.8275V7.17477C2 6.46216 2.43211 5.82071 3.09252 5.55298L10.5911 2.51301ZM12.8453 3.90312C12.3032 3.68334 11.6968 3.68334 11.1547 3.90312L9.24097 4.67894L16.7678 7.60604L19.437 6.57542L12.8453 3.90312ZM14.6911 8.40787L7.21472 5.50039L4.59029 6.56435L12.0013 9.44642L14.6911 8.40787ZM3.5 16.8275C3.5 16.9293 3.56173 17.0209 3.65607 17.0592L11.1547 20.0991C11.1863 20.112 11.2183 20.1241 11.2503 20.1354V10.7638L3.5 7.74979V16.8275ZM12.8453 20.0991L20.3439 17.0592C20.4383 17.0209 20.5 16.9293 20.5 16.8275V7.77292L12.7503 10.7651V20.1352C12.7822 20.1239 12.8139 20.1119 12.8453 20.0991Z" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavManifests" Tag="manifests" Content="Manifests">
                    <muxc:NavigationViewItem.Icon>
                        <!-- Same icon used per-row in the manifest list (Fluent UI
                             document_text_24_regular ≈ Lucide file-text): a document
                             outline with three horizontal lines inside. PathIcon
                             needs a fillable closed path, hence the Fluent variant
                             instead of the Lucide stroke path used in the list. -->
                        <PathIcon Data="M5.5 4C5.5 3.72386 5.72386 3.5 6 3.5H13V7.25C13 8.2165 13.7835 9 14.75 9H18.5V20C18.5 20.2761 18.2761 20.5 18 20.5H6C5.72386 20.5 5.5 20.2761 5.5 20V4ZM14.5 4.06066L17.9393 7.5H14.75C14.6119 7.5 14.5 7.38807 14.5 7.25V4.06066ZM4 4C4 2.89543 4.89543 2 6 2H13.1716C13.702 2 14.2107 2.21071 14.5858 2.58579L19.4142 7.41421C19.7893 7.78929 20 8.29799 20 8.82843V20C20 21.1046 19.1046 22 18 22H6C4.89543 22 4 21.1046 4 20V4ZM7.75 13C7.33579 13 7 13.3358 7 13.75C7 14.1642 7.33579 14.5 7.75 14.5H16.25C16.6642 14.5 17 14.1642 17 13.75C17 13.3358 16.6642 13 16.25 13H7.75ZM7 17.25C7 16.8358 7.33579 16.5 7.75 16.5H13.25C13.6642 16.5 14 16.8358 14 17.25C14 17.6642 13.6642 18 13.25 18H7.75C7.33579 18 7 17.6642 7 17.25Z" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavCatalogs" Tag="catalogs" Content="Catalogs">
                    <muxc:NavigationViewItem.Icon>
                        <PathIcon Data="M4 3H5C6.05382 3 6.91812 3.8164 6.99451 4.85081L7 5V19C7 20.0538 6.1836 20.9181 5.14919 20.9945L5 21H4C2.94618 21 2.08188 20.1836 2.00549 19.1492L2 19V5C2 3.94618 2.8164 3.08188 3.85081 3.00549L4 3ZM10 3H11C12.0538 3 12.9181 3.8164 12.9945 4.85081L13 5V19C13 20.0538 12.1836 20.9181 11.1492 20.9945L11 21H10C8.94618 21 8.08188 20.1836 8.00549 19.1492L8 19V5C8 3.94618 8.8164 3.08188 9.85081 3.00549L10 3ZM16.9743 5.0005C17.8138 5.0005 18.5825 5.5311 18.8643 6.34636L18.9113 6.5025L21.9263 18.2485C22.1888 19.2689 21.613 20.3094 20.6295 20.6402L20.4863 20.6825L19.5173 20.9315C19.3513 20.9735 19.1833 20.9945 19.0193 20.9945C18.1807 20.9945 17.4112 20.463 17.1302 19.6476L17.0833 19.4915L14.0673 7.7465C13.8058 6.72514 14.3807 5.68555 15.3649 5.35484L15.5083 5.3125L16.4763 5.0635C16.6423 5.0205 16.8103 5.0005 16.9743 5.0005ZM5 4.5H4C3.75467 4.5 3.55042 4.67778 3.50806 4.91043L3.5 5V19C3.5 19.2444 3.67699 19.4494 3.91016 19.4919L4 19.5H5C5.24533 19.5 5.44958 19.3222 5.49194 19.0896L5.5 19V5C5.5 4.75556 5.32301 4.55062 5.08984 4.50809L5 4.5ZM11 4.5H10C9.75467 4.5 9.55042 4.67778 9.50806 4.91043L9.5 5V19C9.5 19.2444 9.67699 19.4494 9.91016 19.4919L10 19.5H11C11.2453 19.5 11.4496 19.3222 11.4919 19.0896L11.5 19V5C11.5 4.75556 11.323 4.55062 11.0898 4.50809L11 4.5ZM16.9753 6.5005L16.9119 6.50437L16.8493 6.5165L15.8813 6.7645C15.7063 6.8095 15.6143 6.9275 15.5743 6.9955C15.5431 7.0483 15.4985 7.14718 15.5049 7.27422L15.5203 7.3745L18.5363 19.1185C18.6023 19.3765 18.8333 19.4945 19.0193 19.4945L19.0818 19.4906L19.1443 19.4785L20.1133 19.2295C20.3515 19.1691 20.5052 18.9458 20.4879 18.7102L20.4733 18.6215L17.4583 6.8755C17.3913 6.6185 17.1613 6.5005 16.9753 6.5005Z" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavGit" Tag="git" Content="Git">
                    <muxc:NavigationViewItem.Icon>
                        <PathIcon Data="M4 5.5C4 3.567 5.567 2 7.5 2C9.433 2 11 3.567 11 5.5C11 7.08956 9.94036 8.43162 8.48893 8.85834C9.17679 11.1112 11.272 12.75 13.75 12.75H14.0805C14.4239 11.1774 15.8244 10 17.5 10C19.433 10 21 11.567 21 13.5C21 15.433 19.433 17 17.5 17C15.8244 17 14.4239 15.8226 14.0805 14.25H13.75C11.519 14.25 9.53183 13.2063 8.25 11.5805L8.25 15.0805C9.82259 15.4239 11 16.8244 11 18.5C11 20.433 9.433 22 7.5 22C5.567 22 4 20.433 4 18.5C4 16.8244 5.17741 15.4239 6.75 15.0805L6.75 8.91946C5.17741 8.57612 4 7.17556 4 5.5ZM7.5 3.5C6.39543 3.5 5.5 4.39543 5.5 5.5C5.5 6.60457 6.39543 7.5 7.5 7.5C8.60457 7.5 9.5 6.60457 9.5 5.5C9.5 4.39543 8.60457 3.5 7.5 3.5ZM7.5 16.5C6.39543 16.5 5.5 17.3954 5.5 18.5C5.5 19.6046 6.39543 20.5 7.5 20.5C8.60457 20.5 9.5 19.6046 9.5 18.5C9.5 17.3954 8.60457 16.5 7.5 16.5ZM15.5 13.5C15.5 14.6046 16.3954 15.5 17.5 15.5C18.6046 15.5 19.5 14.6046 19.5 13.5C19.5 12.3954 18.6046 11.5 17.5 11.5C16.3954 11.5 15.5 12.3954 15.5 13.5Z" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="NavImport" Tag="import" Content="Import">
                    <muxc:NavigationViewItem.Icon>
                        <!-- Fluent UI System Icons: ArrowDownload — a down arrow over a base
                             line, signalling "bring something into the repository". -->
                        <PathIcon Data="M18.2498 20.5009C18.664 20.5008 19 20.8365 19 21.2507C19 21.6649 18.6644 22.0008 18.2502 22.0009L5.25022 22.0047C4.836 22.0048 4.5 21.6691 4.5 21.2549C4.5 20.8407 4.83557 20.5048 5.24978 20.5047L18.2498 20.5009ZM11.6482 2.01271L11.75 2.00586C12.1297 2.00586 12.4435 2.28801 12.4932 2.65409L12.5 2.75586L12.499 16.4409L16.2208 12.7205C16.4871 12.4543 16.9038 12.4301 17.1974 12.648L17.2815 12.7206C17.5477 12.9869 17.5719 13.4036 17.354 13.6972L17.2814 13.7813L12.2837 18.7779C12.0176 19.044 11.6012 19.0683 11.3076 18.8507L11.2235 18.7782L6.22003 13.7816C5.92694 13.4889 5.92661 13.014 6.21931 12.7209C6.48539 12.4545 6.90204 12.43 7.1958 12.6477L7.27997 12.7202L10.999 16.4339L11 2.75586C11 2.37616 11.2822 2.06237 11.6482 2.01271L11.75 2.00586L11.6482 2.01271Z" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
