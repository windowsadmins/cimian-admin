<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CimianStudio.Views.CatalogCompareDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:packages="using:CimianStudio.Core.Models.Packages"
    Title="Compare catalogs"
    PrimaryButtonText="Close"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1100</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">820</x:Double>
        <DataTemplate x:Key="PackageRowTemplate" x:DataType="packages:Package">
            <Grid Padding="6,3,6,3" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Bind Name}" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind Version}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
    </ContentDialog.Resources>

    <Grid RowSpacing="12" Width="980" Height="640">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Catalog A" Style="{StaticResource CaptionTextBlockStyle}" />
                <ComboBox x:Name="CatalogABox"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="select…"
                          SelectionChanged="OnSelectionChanged" />
            </StackPanel>
            <Viewbox Grid.Column="1" Width="18" Height="18" VerticalAlignment="Bottom" Margin="0,0,0,8">
                <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                      Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                      Data="M18,8 L22,12 L18,16 M2,12 L22,12" />
            </Viewbox>
            <StackPanel Grid.Column="2" Spacing="2">
                <TextBlock Text="Catalog B" Style="{StaticResource CaptionTextBlockStyle}" />
                <ComboBox x:Name="CatalogBBox"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="select…"
                          SelectionChanged="OnSelectionChanged" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            Padding="10,6,10,6">
                        <TextBlock x:Name="OnlyAHeader"
                                   Text="Only in A"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </Border>
                    <ListView Grid.Row="1" x:Name="OnlyAList"
                              Padding="0,4,0,4"
                              ItemTemplate="{StaticResource PackageRowTemplate}"
                              DoubleTapped="OnPackageDoubleTapped"
                              IsItemClickEnabled="True" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            Padding="10,6,10,6">
                        <TextBlock x:Name="OnlyBHeader"
                                   Text="Only in B"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </Border>
                    <ListView Grid.Row="1" x:Name="OnlyBList"
                              Padding="0,4,0,4"
                              ItemTemplate="{StaticResource PackageRowTemplate}"
                              DoubleTapped="OnPackageDoubleTapped"
                              IsItemClickEnabled="True" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            Padding="10,6,10,6">
                        <TextBlock x:Name="BothHeader"
                                   Text="In both"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </Border>
                    <ListView Grid.Row="1" x:Name="BothList"
                              Padding="0,4,0,4"
                              ItemTemplate="{StaticResource PackageRowTemplate}"
                              DoubleTapped="OnPackageDoubleTapped"
                              IsItemClickEnabled="True" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentDialog>
