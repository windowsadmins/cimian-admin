<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CimianStudio.Views.ContextualChipList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- ListViewItem stripped of selection highlight + tight padding so the inner
             Border (the chip body) renders flush. -->
        <Style x:Key="ChipRowStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Resources>

    <StackPanel Spacing="6">
        <AutoSuggestBox x:Name="Picker"
                        QueryIcon="Find"
                        TextChanged="OnPickerTextChanged"
                        SuggestionChosen="OnPickerSuggestionChosen"
                        QuerySubmitted="OnPickerQuerySubmitted" />
        <ListView x:Name="ChipsHost"
                  SelectionMode="None"
                  CanReorderItems="True"
                  AllowDrop="True"
                  CanDragItems="True"
                  ShowsScrollingPlaceholders="False"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ItemContainerStyle="{StaticResource ChipRowStyle}"
                  DragItemsCompleted="OnChipsReordered">
            <!-- Non-virtualizing panel: the chip list lives inside the editor's
                 ScrollViewer, so we don't want the ListView's own virtualizing
                 ItemsStackPanel (which would refuse to realize children given
                 unbounded vertical space) — otherwise chips silently never render. -->
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>
    </StackPanel>
</UserControl>
