<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianStudio.Views.GitPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:CimianStudio.Views"
    KeyboardAcceleratorPlacementMode="Hidden">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Modifiers="Control" Key="A" Invoked="OnSelectAllAccelerator" />
        <KeyboardAccelerator Modifiers="Control,Shift" Key="A" Invoked="OnSelectNoneAccelerator" />
        <KeyboardAccelerator Modifiers="Control" Key="Enter" Invoked="OnCommitAccelerator" />
        <KeyboardAccelerator Key="F5" Invoked="OnRefreshAccelerator" />
        <KeyboardAccelerator Key="Space" Invoked="OnSpaceAccelerator" />
    </Page.KeyboardAccelerators>

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: title + (branch picker, ahead/behind chip, Fetch/Pull/Help) on one row. -->
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Git"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                    <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                          Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                          Data="M6,3 V15 M15,6 A3,3 0 1 0 21,6 A3,3 0 1 0 15,6 Z M3,18 A3,3 0 1 0 9,18 A3,3 0 1 0 3,18 Z M18,9 A9,9 0 0 1 9,18" />
                </Viewbox>
                <TextBlock Text="Branch:" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="BranchPicker"
                          MinWidth="220"
                          SelectionChanged="OnBranchSelectionChanged" />
                <!-- Ahead/behind status rendered to match the adjacent Fetch/Pull buttons:
                     same corner radius, same control surface, same height. Becomes
                     visible only when there's something to report. -->
                <Border x:Name="AheadBehindChip"
                        Visibility="Collapsed"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Padding="11,5,11,6"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AheadBehindText"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" />
                </Border>
                <Button x:Name="FetchButton" Content="Fetch" Click="OnFetchClicked" Margin="6,0,0,0">
                    <ToolTipService.ToolTip>
                        <TextBlock Text="git fetch --all --prune" />
                    </ToolTipService.ToolTip>
                </Button>
                <Button x:Name="PullButton" Content="Pull" Click="OnPullClicked">
                    <ToolTipService.ToolTip>
                        <TextBlock Text="git pull --rebase --autostash" />
                    </ToolTipService.ToolTip>
                </Button>
                <Button x:Name="HelpButton" Click="OnHelpClicked" Width="36">
                    <Button.Content>
                        <Viewbox Width="14" Height="14">
                            <Path Width="24" Height="24" Style="{StaticResource LucidePath}" Data="M2,12 A10,10 0 1 0 22,12 A10,10 0 1 0 2,12 Z M9.09,9 A3,3 0 0 1 14.92,10 C14.92,12 11.92,13 11.92,13 M12,17 L12.01,17" />
                        </Viewbox>
                    </Button.Content>
                    <ToolTipService.ToolTip>
                        <TextBlock Text="Keyboard shortcuts (?)" />
                    </ToolTipService.ToolTip>
                </Button>
                <!-- Relative time since the last fetch/pull. Sourced from .git/FETCH_HEAD
                     mtime so it survives app restarts and reflects fetches done outside
                     the app (CLI, IDE). Updated on a one-minute timer. -->
                <TextBlock x:Name="LastFetchText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />
            </StackPanel>
            <TextBlock x:Name="ScopeLine"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <!-- Pivot wraps body: Changes (current two-pane editor) + History (commit log). -->
        <Pivot Grid.Row="1" x:Name="BodyPivot" SelectionChanged="OnPivotSelectionChanged">
            <PivotItem Header="Changes" Margin="0,16,0,0">
        <Grid x:Name="BodyGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="240" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="3*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <!-- Composer first: write the commit message before picking files. -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock Text="Subject (≤72 chars recommended)"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox x:Name="SubjectBox"
                             PlaceholderText="Promote Office 2025 to Production"
                             TextChanged="OnSubjectChanged" />
                    <TextBlock Text="Body (optional)"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Margin="0,4,0,0" />
                    <TextBox x:Name="BodyBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Mono, Consolas"
                             MinHeight="64"
                             MaxHeight="140" />
                </StackPanel>

                <!-- Identity gets its own row so a narrow window can't crush it; the
                     action row below stays full-width with checkboxes + commit buttons. -->
                <Grid Grid.Row="1" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                            <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                  Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                  Data="M19,21 V19 A4,4 0 0 0 15,15 H9 A4,4 0 0 0 5,19 V21 M8,7 A4,4 0 1 0 16,7 A4,4 0 1 0 8,7 Z" />
                        </Viewbox>
                        <!-- Click the name/email to open the identity editor — no
                             separate Edit button. HyperlinkButton renders as a flat
                             text link styled like the surrounding caption. -->
                        <HyperlinkButton x:Name="EditIdentityButton"
                                         Padding="0"
                                         Click="OnEditIdentityClicked">
                            <TextBlock x:Name="IdentityText"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Text="(no identity)" />
                        </HyperlinkButton>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right">
                        <!-- Per-commit toggles. Amend rewrites the previous commit instead of
                             creating a new one. Skip hooks passes the no-verify switch and
                             replaces the old overflow menu item. -->
                        <CheckBox x:Name="AmendCheckBox"
                                  Content="Amend"
                                  IsEnabled="False"
                                  VerticalAlignment="Center">
                            <ToolTipService.ToolTip>
                                <TextBlock Text="Rewrite the previous commit instead of creating a new one (--amend)." />
                            </ToolTipService.ToolTip>
                        </CheckBox>
                        <CheckBox x:Name="SkipHooksCheckBox"
                                  Content="Skip hooks"
                                  IsEnabled="False"
                                  VerticalAlignment="Center">
                            <ToolTipService.ToolTip>
                                <TextBlock Text="Bypass pre-commit and commit-msg hooks (--no-verify)." />
                            </ToolTipService.ToolTip>
                        </CheckBox>
                        <Button x:Name="CommitButton"
                                Content="Commit"
                                IsEnabled="False"
                                Click="OnCommitClicked">
                            <ToolTipService.ToolTip>
                                <TextBlock Text="Commit selected files (Ctrl+Enter)" />
                            </ToolTipService.ToolTip>
                        </Button>
                        <Button x:Name="CommitPushButton"
                                Content="Commit &amp; push"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="False"
                                Click="OnCommitPushClicked" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" MinHeight="36" VerticalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock x:Name="ChangesHeader"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button x:Name="SelectAllButton" Content="Select all" Click="OnSelectAllClicked">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Toggle all (a) — Ctrl+A also" />
                        </ToolTipService.ToolTip>
                    </Button>
                    <Button x:Name="SelectNoneButton" Content="Clear" Click="OnSelectNoneClicked">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Clear selection (Ctrl+Shift+A)" />
                        </ToolTipService.ToolTip>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3"
                        Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                    <Grid>
                        <ListView x:Name="ChangesList"
                                  SelectionMode="Single"
                                  IsItemClickEnabled="True"
                                  ItemClick="OnChangeItemClicked"
                                  SelectionChanged="OnChangeSelectionChanged"
                                  KeyDown="OnChangesListKeyDown"
                                  Padding="6" />
                        <TextBlock x:Name="EmptyState"
                                   Text="Working tree clean — no changes to commit."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="NoGitState"
                                   Text="No git repository detected for this Cimian deployment."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </Grid>
                </Border>
            </Grid>

            <controls:GridSplitter Grid.Column="1"
                                   Width="6"
                                   Background="Transparent"
                                   ResizeBehavior="PreviousAndNext"
                                   ResizeDirection="Columns" />

            <Grid Grid.Column="2" RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="DiffHeader"
                               Text="Diff"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <HyperlinkButton Grid.Column="1"
                                     x:Name="OpenInEditorButton"
                                     Content="Open in editor"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Center"
                                     Click="OnOpenInEditorClicked">
                        <ToolTipService.ToolTip>
                            <TextBlock Text="Open in editor (o)" />
                        </ToolTipService.ToolTip>
                    </HyperlinkButton>
                </Grid>

                <Border Grid.Row="1"
                        Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                    <Grid>
                        <ScrollViewer x:Name="DiffScroller"
                                      HorizontalScrollMode="Enabled"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="10">
                            <TextBlock x:Name="DiffText"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="12"
                                       TextWrapping="NoWrap"
                                       IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                        <TextBlock x:Name="DiffPlaceholder"
                                   Text="Select a changed file to see its diff."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
            </PivotItem>

            <PivotItem Header="History" Margin="0,16,0,0">
                <!-- Two-pane: commit list on the left, selected commit's diff on the right. -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="320" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                        <Grid>
                            <ListView x:Name="HistoryList"
                                      SelectionMode="Single"
                                      SelectionChanged="OnHistorySelectionChanged"
                                      Padding="0,2,0,2">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4,0,8,0" ColumnSpacing="8" MinHeight="28">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Edit Commit Message..."
                                                                    Click="OnEditCommitMessageClicked" />
                                                    <MenuFlyoutItem Text="Tag..."
                                                                    Click="OnTagCommitClicked" />
                                                    <MenuFlyoutItem Text="Create Branch..."
                                                                    Click="OnCreateBranchAtClicked" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Checkout"
                                                                    Click="OnCheckoutCommitClicked" />
                                                    <MenuFlyoutItem Text="Cherry-Pick"
                                                                    Click="OnCherryPickClicked" />
                                                    <MenuFlyoutItem Text="Revert"
                                                                    Click="OnRevertCommitClicked" />
                                                    <MenuFlyoutItem Text="Merge"
                                                                    Click="OnMergeCommitClicked" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Rebase onto This"
                                                                    Click="OnRebaseOntoClicked" />
                                                    <MenuFlyoutItem Text="Reset to This..."
                                                                    Click="OnResetToClicked" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Copy Hash"
                                                                    Click="OnCopyShaClicked" />
                                                    <MenuFlyoutItem Text="Copy Subject"
                                                                    Click="OnCopySubjectClicked" />
                                                    <MenuFlyoutItem Text="Copy as .patch"
                                                                    Click="OnCopyPatchClicked" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="14" />
                                                <ColumnDefinition Width="84" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Lane graph -->
                                            <local:GraphCanvas Grid.Column="0"
                                                               LaneRow="{Binding LaneRow}"
                                                               VerticalAlignment="Center" />
                                            <!-- Abbreviated SHA -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Sha}"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <!-- Ref badges -->
                                            <ItemsControl Grid.Column="2"
                                                          ItemsSource="{Binding Refs}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="3" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{Binding Background}"
                                                                BorderBrush="{Binding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="3"
                                                                Padding="4,1,4,1">
                                                            <TextBlock Text="{Binding Label}"
                                                                       FontSize="10"
                                                                       Foreground="White" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Subject -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Subject}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <!-- Author -->
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding AuthorName}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <!-- Date -->
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding WhenDisplay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock x:Name="HistoryEmpty"
                                       Text="No commits yet on this branch."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <ProgressRing x:Name="HistoryLoading"
                                          IsActive="False"
                                          Width="32"
                                          Height="32" />
                        </Grid>
                    </Border>

                    <controls:GridSplitter Grid.Column="1"
                                           Width="6"
                                           Background="Transparent"
                                           ResizeBehavior="PreviousAndNext"
                                           ResizeDirection="Columns" />

                    <Border Grid.Column="2"
                            Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                        <Grid>
                            <ScrollViewer x:Name="HistoryDiffScroller"
                                          HorizontalScrollMode="Enabled"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="10">
                                <TextBlock x:Name="HistoryDiffText"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="12"
                                           TextWrapping="NoWrap"
                                           IsTextSelectionEnabled="True" />
                            </ScrollViewer>
                            <TextBlock x:Name="HistoryDiffPlaceholder"
                                       Text="Select a commit to see its diff."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <ProgressRing x:Name="HistoryDiffLoading"
                                          IsActive="False"
                                          Width="32"
                                          Height="32" />
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

            <PivotItem Header="Hooks" Margin="0,16,0,0">
                <!-- Two-pane: hook list on the left, editable hook content on the right. -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="200" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="300" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- Source label + resolved path on a single row -->
                            <Grid Grid.Row="0" Padding="8,6,8,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HooksDirSourceLabel"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           Text="Hooks directory" />
                                <TextBlock x:Name="HooksDirCaption"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            </Grid>
                            <ListView x:Name="HooksList"
                                      Grid.Row="1"
                                      SelectionMode="Single"
                                      SelectionChanged="OnHookSelectionChanged"
                                      Padding="0,4,0,4">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="6,6,6,6" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!-- State dot: green filled for Active, hollow grey for Inactive,
                                                 orange for Disabled, blue for Sample. -->
                                            <Ellipse Grid.Column="0"
                                                     Width="10" Height="10"
                                                     Fill="{Binding DotFill}"
                                                     Stroke="{Binding DotStroke}"
                                                     StrokeThickness="1.5"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       Foreground="{Binding NameForeground}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StateDisplay}"
                                                       Visibility="{Binding StateBadgeVisibility}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock x:Name="HooksEmpty"
                                       Grid.Row="1"
                                       Text="No git repository open."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <ProgressRing x:Name="HooksLoading"
                                          Grid.Row="1"
                                          IsActive="False"
                                          Width="32"
                                          Height="32" />
                        </Grid>
                    </Border>

                    <controls:GridSplitter Grid.Column="1"
                                           Width="6"
                                           Background="Transparent"
                                           ResizeBehavior="PreviousAndNext"
                                           ResizeDirection="Columns" />

                    <Border Grid.Column="2"
                            Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Toolbar: name + toggle + Save (row 0), badges (row 1),
                                 description (row 2), state-specific hint (row 3). -->
                            <Grid x:Name="HookEditorToolbar"
                                  Grid.Row="0"
                                  Padding="10,8,10,8"
                                  RowSpacing="6"
                                  Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="HookEditorTitle"
                                           Grid.Row="0" Grid.Column="0"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch x:Name="HookActiveSwitch"
                                              Grid.Row="0" Grid.Column="1"
                                              Toggled="OnHookActiveSwitchToggled"
                                              MinWidth="80"
                                              VerticalAlignment="Center" />
                                <Button x:Name="HookSaveButton"
                                        Grid.Row="0" Grid.Column="2"
                                        Content="Save"
                                        Click="OnSaveHookClicked"
                                        IsEnabled="False"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center" />

                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                            Orientation="Horizontal" Spacing="6">
                                    <Border x:Name="HookStateChip"
                                            CornerRadius="4"
                                            Padding="6,2,6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="HookStateChipText"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="White" />
                                    </Border>
                                    <Border x:Name="HookKindChip"
                                            CornerRadius="4"
                                            Padding="6,2,6,2"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                                        <TextBlock x:Name="HookKindChipText"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="White" />
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="HookDescriptionText"
                                           Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <TextBlock x:Name="HookHintText"
                                           Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           Visibility="Collapsed" />
                            </Grid>

                            <!-- Editable content (active/disabled/missing hooks) -->
                            <TextBox x:Name="HookContentEdit"
                                     Grid.Row="1"
                                     AcceptsReturn="True"
                                     FontFamily="Cascadia Mono, Consolas"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     TextChanged="OnHookContentChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />

                            <!-- Placeholder -->
                            <TextBlock x:Name="HookContentPlaceholder"
                                       Grid.Row="1"
                                       Text="Select a hook to view its content."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>
        </Pivot>

        <Grid Grid.Row="2">
            <InfoBar x:Name="ResultBar"
                     IsClosable="True"
                     IsOpen="False" />

            <!-- Live progress overlay: appears whenever a git operation is running so
                 the app never sits silently while hooks/network do their thing. -->
            <Border x:Name="ProgressOverlay"
                    Visibility="Collapsed"
                    Style="{StaticResource CardStyle}" Shadow="{StaticResource CardShadow}" Translation="0,0,16"
                    Padding="12,10,12,10">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <ProgressRing x:Name="ProgressRing" IsActive="True" Width="18" Height="18" />
                        <TextBlock x:Name="ProgressTitle"
                                   Text="Running…"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Row="1"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="ProgressScroller"
                                      MaxHeight="120"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="8,6,8,6">
                            <TextBlock x:Name="ProgressText"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="11"
                                       TextWrapping="NoWrap"
                                       IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
