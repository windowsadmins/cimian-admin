<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CimianStudio.Views.ManifestSearchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Find manifests"
    PrimaryButtonText="Apply"
    SecondaryButtonText="Clear"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">820</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">620</x:Double>
    </ContentDialog.Resources>

    <Grid Width="760" Height="460" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <ComboBox x:Name="MatchModeCombo" MinWidth="80">
                <ComboBoxItem Content="All" Tag="All" />
                <ComboBoxItem Content="Any" Tag="Any" />
            </ComboBox>
            <TextBlock Text="of the following are true"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="RowsHost" Spacing="6" Padding="8" />
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2"
                Content="+ Add rule"
                Click="OnAddRuleClicked"
                HorizontalAlignment="Left" />
    </Grid>
</ContentDialog>
