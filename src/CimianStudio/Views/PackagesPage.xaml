<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CimianStudio.Views.PackagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:nodes="using:CimianStudio.Models"
    xmlns:local="using:CimianStudio.Views">

    <!-- Page-wide drag-drop. Dropping installer files anywhere on Packages
         routes them straight into the Import wizard so users don't have to
         switch tabs first. -->
    <Grid Padding="16,12,16,16"
          ColumnSpacing="16"
          AllowDrop="True"
          DragOver="OnInstallerDragOver"
          Drop="OnInstallerDrop">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Shadow="{StaticResource CardShadow}"
                Translation="0,0,16">
        <Grid Padding="16,16,16,16" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Packages" Style="{StaticResource SubtitleTextBlockStyle}" />
            <!-- Search box on the left fills available width; "Find" button on the right
                 opens the smart-search dialog (attribute · operator · value rules). -->
            <Grid Grid.Row="1" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         PlaceholderText="Search packages"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        x:Name="FindButton"
                        Click="OnFindClicked"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Viewbox Width="14" Height="14">
                            <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                  Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                  Data="M22,3 H2 L10,12.46 V19 L14,21 V12.46 Z" />
                        </Viewbox>
                        <TextBlock x:Name="FindButtonText"
                                   Text="Find"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ToolTipService.ToolTip>
                        <TextBlock Text="Build a criteria search (attribute · operator · value)" />
                    </ToolTipService.ToolTip>
                </Button>
            </Grid>
            <!-- Group / sort selectors. Group changes the buckets at the top level;
                 sort orders the leaves within each bucket. Code-behind owns the
                 selection bridge so the ComboBox SelectedIndex maps to the enum. -->
            <Grid Grid.Row="2" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          x:Name="GroupByCombo"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="OnGroupByChanged">
                    <ComboBoxItem Content="By category" Tag="Categories" />
                    <ComboBoxItem Content="By developer" Tag="Developers" />
                    <ComboBoxItem Content="By directory" Tag="Directories" />
                    <ComboBoxItem Content="By type" Tag="Types" />
                    <ComboBoxItem Content="All packages" Tag="None" />
                </ComboBox>
                <ComboBox Grid.Column="1"
                          x:Name="SortByCombo"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="OnSortByChanged">
                    <ComboBoxItem Content="Sort: Name" Tag="Name" />
                    <ComboBoxItem Content="Sort: Recently modified" Tag="RecentlyModified" />
                    <ComboBoxItem Content="Sort: Recently created" Tag="RecentlyCreated" />
                </ComboBox>
            </Grid>
            <TextBlock
                Grid.Row="3"
                x:Name="CountText"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <muxc:TreeView
                Grid.Row="4"
                x:Name="PackagesTree"
                ItemsSource="{x:Bind ViewModel.RootNodes, Mode=OneWay}"
                ItemInvoked="OnNodeInvoked"
                SelectionMode="Single">
                <muxc:TreeView.ItemTemplate>
                    <DataTemplate x:DataType="nodes:PackageTreeNode">
                        <muxc:TreeViewItem
                            ItemsSource="{x:Bind Children}"
                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                            <muxc:TreeViewItem.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        Text="Open in new window"
                                        Click="OnOpenInNewWindow"
                                        DataContext="{x:Bind}" />
                                </MenuFlyout>
                            </muxc:TreeViewItem.ContextFlyout>
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center">
                                    <Viewbox Visibility="{x:Bind local:PackagesPage.VisIfPackage(HasPackage)}">
                                        <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                              Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                              Data="M7.5,4.27 L16.5,9.42 M21,8 A2,2 0 0 0 20,6.27 L13,2.27 A2,2 0 0 0 11,2.27 L4,6.27 A2,2 0 0 0 3,8 V16 A2,2 0 0 0 4,17.73 L11,21.73 A2,2 0 0 0 13,21.73 L20,17.73 A2,2 0 0 0 21,16 Z M3.3,7 L12,12 L20.7,7 M12,22 V12" />
                                    </Viewbox>
                                    <Viewbox Visibility="{x:Bind local:PackagesPage.VisIfFolder(HasPackage)}">
                                        <Path Width="24" Height="24" Style="{StaticResource LucidePath}"
                                              Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                              Data="M20,20 A2,2 0 0 0 22,18 V8 A2,2 0 0 0 20,6 H12.1 A2,2 0 0 1 10.41,5.1 L9.6,3.9 A2,2 0 0 0 7.93,3 H4 A2,2 0 0 0 2,5 V18 A2,2 0 0 0 4,20 Z" />
                                    </Viewbox>
                                </Grid>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind Package.Version, Mode=OneWay, FallbackValue=''}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Margin="6,0,4,0"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </muxc:TreeViewItem>
                    </DataTemplate>
                </muxc:TreeView.ItemTemplate>
            </muxc:TreeView>
        </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Style="{StaticResource CardStyle}"
            Shadow="{StaticResource CardShadow}"
            Translation="0,0,16">
            <Grid>
                <muxc:ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="48"
                    Height="48" />
                <local:PackageEditor x:Name="Editor" />
            </Grid>
        </Border>
    </Grid>
</Page>
